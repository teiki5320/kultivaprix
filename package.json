{
  "name": "kultivaprix",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "ingest:awin": "tsx scripts/ingest/awin.ts",
    "ingest:effiliation": "tsx scripts/ingest/effiliation.ts",
    "ingest:amazon": "tsx scripts/ingest/amazon.ts",
    "ingest:manomano": "tsx scripts/ingest/manomano.ts",
    "scrape:kokopelli": "tsx scripts/ingest/kokopelli-scraper.ts",
    "scrape:baumaux": "tsx scripts/ingest/baumaux-scraper.ts",
    "scrape:all": "npm run scrape:kokopelli && npm run scrape:baumaux",
    "ingest:all": "npm run ingest:awin && npm run ingest:effiliation && npm run ingest:amazon && npm run ingest:manomano",
    "normalize": "tsx scripts/normalize.ts",
    "refresh": "npm run ingest:all && npm run normalize",
    "sitemap": "tsx scripts/sitemap.ts",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
