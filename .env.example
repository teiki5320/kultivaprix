# =========================================================================
# KULTIVAPRIX — ENVIRONMENT VARIABLES
# Copy this file to `.env.local` for local dev, and set them in Vercel
# (Project → Settings → Environment Variables) for production.
# Same vars must be set as GitHub Actions secrets for scheduled jobs.
# =========================================================================

# ---- Site ----
NEXT_PUBLIC_SITE_URL=https://kultivaprix.com
NEXT_PUBLIC_KULTIVA_APP_URL=https://kultiva.app

# ---- Supabase (projet Kultiva existant — PARTAGÉ) ----
# Kultivaprix n'a PAS son propre projet Supabase.
# On réutilise le projet Supabase de l'app Kultiva, mais toutes les tables
# vivent dans le schéma dédié `kultivaprix` (voir supabase/migrations).
#
# Où trouver les clés : Supabase dashboard du projet Kultiva → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<KULTIVA_PROJECT_REF>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...PUBLIC_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...SERVICE_ROLE_KEY

# ⚠ Étape manuelle obligatoire côté Supabase Dashboard du projet Kultiva :
# Project Settings → API → "Exposed schemas" → ajouter `kultivaprix`
# (sinon PostgREST refuse les requêtes anon/service_role sur ce schéma)

# ---- Awin (affiliation) ----
AWIN_API_TOKEN=PLACEHOLDER_AWIN_TOKEN
AWIN_PUBLISHER_ID=PLACEHOLDER_PUBLISHER_ID
AWIN_ADVERTISER_IDS=

# ---- Effiliation ----
EFFILIATION_API_KEY=PLACEHOLDER_EFFILIATION_KEY
EFFILIATION_ID=PLACEHOLDER_EFFILIATION_ID
EFFILIATION_PROGRAM_IDS=

# ---- Amazon Partenaires (Product Advertising API 5.0) ----
AMAZON_PA_ACCESS_KEY=PLACEHOLDER_AMAZON_ACCESS
AMAZON_PA_SECRET_KEY=PLACEHOLDER_AMAZON_SECRET
AMAZON_PA_PARTNER_TAG=kultivaprix-21
AMAZON_PA_HOST=webservices.amazon.fr
AMAZON_PA_REGION=eu-west-1

# ---- ManoMano (via Awin ou direct feed) ----
MANOMANO_FEED_URL=

# ---- Scraping (Playwright) ----
PLAYWRIGHT_HEADFUL=false
SCRAPER_USER_AGENT="KultivaprixBot/0.1 (+https://kultivaprix.com/bot)"

# ---- Vercel ----
VERCEL_DEPLOY_HOOK_URL=

# ---- Cron protection ----
CRON_SECRET=PLACEHOLDER_RANDOM_STRING_32_CHARS
